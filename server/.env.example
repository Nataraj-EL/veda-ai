NODE_ENV=development
PORT=3001
CLIENT_ORIGIN=http://localhost:3000

MONGODB_URI=mongodb://127.0.0.1:27017/vedam-ai

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=
REDIS_TLS=false

# BullMQ
GENERATION_QUEUE_NAME=assessment-generation
GENERATION_JOB_ATTEMPTS=3
GENERATION_JOB_BACKOFF_MS=5000

# AI (Gemini preferred when GEMINI_API_KEY is set)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Run worker in same process (dev convenience). Use `npm run worker` in production.
EMBED_WORKER=true

LOG_LEVEL=info
